# MatchProp v2.0 — Variables mínimas para demo local
# Copiar a apps/api/.env y completar

# Base de datos
DATABASE_URL="postgresql://matchprop:matchprop@localhost:5432/matchprop"

# Auth
JWT_SECRET="cambiar-en-produccion-min-32-chars"
AUTH_REFRESH_SECRET="cambiar-en-produccion"
APP_URL="http://localhost:3000"
API_PUBLIC_URL="http://localhost:3001"
COOKIE_SECURE="false"

# Demo / beta fundadora
DEMO_MODE="1"

# Kiteprop (fixture para demo local)
KITEPROP_EXTERNALSITE_MODE="fixture"

# Integraciones (opcional para demo)
INTEGRATIONS_MASTER_KEY="opcional-32-chars-min"

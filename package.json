{
  "name": "matchprop",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "clean:test": "bash scripts/clean-for-test.sh",
    "clean:web": "rm -rf apps/web/.next",
    "dev": "pnpm --parallel -r run dev",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "dev:api": "pnpm build:shared && pnpm --filter api dev",
    "dev:admin": "pnpm --filter admin dev",
    "dev:mobile": "pnpm --filter mobile dev",
    "dev:web": "pnpm build:shared && pnpm --filter web dev",
    "build": "pnpm -r --filter '!mobile' run build",
    "build:api": "pnpm --filter api build",
    "build:admin": "pnpm --filter admin build",
    "build:mobile": "pnpm --filter mobile build",
    "build:shared": "pnpm --filter shared build",
    "lint": "eslint \"apps/**/*.{ts,tsx}\" \"packages/**/*.{ts,tsx}\"",
    "lint:fix": "eslint --fix \"apps/**/*.{ts,tsx}\" \"packages/**/*.{ts,tsx}\"",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "smoke:ux": "bash scripts/smoke-ux.sh",
    "smoke:prod": "bash scripts/smoke-prod.sh",
    "verify:deploy": "bash scripts/verify-deploy-status.sh",
    "deploy:pre": "bash scripts/deploy-pre.sh",
    "pre-deploy:verify": "bash scripts/pre-deploy-verify.sh",
    "demo:up": "bash scripts/demo-up-and-smoke.sh",
    "dev:up": "bash scripts/dev-up.sh",
    "dev-local": "bash scripts/dev-local.sh",
    "dev:down": "bash scripts/dev-down.sh",
    "deploy:git": "bash scripts/deploy-git.sh",
    "audit:verify": "bash scripts/audit-verify.sh",
    "audit:pack": "bash scripts/audit-pack.sh",
    "mock:crm": "node scripts/mock-crm-webhook.mjs",
    "start": "pnpm dev:up",
    "iniciar": "pnpm dev:up",
    "start:check": "pnpm dev:up && pnpm -r typecheck && pnpm --filter api test:all && pnpm smoke:ux"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.10.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}

{
  "version": 2,
  "builds": [
    {
      "src": "api/handler.ts",
      "use": "@vercel/node",
      "config": { "maxLambdaSize": "50mb" }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/api/handler" }
  ],
  "buildCommand": "cd ../.. && pnpm install && pnpm build:shared && pnpm --filter api prisma:generate && pnpm --filter api build",
  "installCommand": "cd ../.. && pnpm install",
  "framework": null
}

# MatchProp API — Producción
# Copiar a .env y completar valores reales. Nunca commitear .env.

# Base de datos
DATABASE_URL="postgresql://user:password@host:5432/matchprop"

# Auth (obligatorio en prod)
JWT_SECRET="generar-con-openssl-rand-base64-32"
AUTH_REFRESH_SECRET="generar-con-openssl-rand-base64-32"

# URLs públicas
APP_URL="https://tu-dominio.com"
API_PUBLIC_URL="https://api.tu-dominio.com"
CORS_ORIGINS="https://tu-dominio.com,https://www.tu-dominio.com"

# Cookies (obligatorio en prod)
COOKIE_SECURE="true"

# Producción: sin demo
DEMO_MODE="0"

# OAuth callbacks
OAUTH_SUCCESS_REDIRECT_URL="https://tu-dominio.com/dashboard"
OAUTH_FAILURE_REDIRECT_URL="https://tu-dominio.com/login?error=oauth"
OAUTH_CALLBACK_BASE_URL="https://api.tu-dominio.com"

# WebAuthn (dominio de prod)
WEBAUTHN_RP_ID="tu-dominio.com"
WEBAUTHN_RP_NAME="MatchProp"
WEBAUTHN_ORIGIN="https://tu-dominio.com"

# Opcional: Kiteprop, CRM push, etc.
INTEGRATIONS_MASTER_KEY=""
CRM_WEBHOOK_URL=""
CRM_WEBHOOK_SECRET=""
# Respuestas inmobiliaria → API (ver docs/WEBHOOKS_KITEPROP.md)
WEBHOOK_INBOUND_SECRET=""
# Push prueba Yumblin (solo QA)
ENABLE_YUMBLIN_TEST_PUSH="0"

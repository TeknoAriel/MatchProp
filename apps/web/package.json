{
  "name": "web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000 --hostname 0.0.0.0",
    "dev:turbo": "next dev --turbo --port 3000 --hostname 0.0.0.0",
    "build": "next build",
    "prestart": "node -e \"try{require('fs').accessSync('.next/BUILD_ID')}catch(e){console.error('Falta build de Next: desde la raíz del repo ejecutá pnpm --filter web build o usá pnpm dev:web (no uses start sin build).');process.exit(1)}\"",
    "start": "next start -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "echo 'no tests'",
    "smoke:ux": "playwright test e2e/smoke-ux.spec.ts",
    "test:responsive": "playwright test e2e/responsive.spec.ts"
  },
  "dependencies": {
    "@matchprop/shared": "workspace:*",
    "@simplewebauthn/browser": "^10.0.0",
    "leaflet": "^1.9.4",
    "next": "^15.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-leaflet": "^4.2.1",
    "react-window": "^1.8.10"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.8",
    "@types/react-window": "^1.8.8",
    "@playwright/test": "^1.49.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.56.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0"
  }
}

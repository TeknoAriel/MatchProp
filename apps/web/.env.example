NEXT_PUBLIC_PRODUCT_NAME="MatchProp"
# API URL (cliente). Proxy server-side usa API_SERVER_URL.
NEXT_PUBLIC_API_URL="http://localhost:3001"
# Opcional: misma clave pública VAPID que en la API (evita depender solo de GET /notifications/push-config)
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
# Producción: API_SERVER_URL=https://api.tu-dominio.com (rewrites /api/*)
NEXT_PUBLIC_BUILD_ID=dev
# Modo prueba: funciones premium sin límites 3-6 meses.
NEXT_PUBLIC_PREMIUM_GRACE_PERIOD=1
# Beta pública: franja superior en la app (1 = activo). Opcional: URL de feedback (formulario, issues, mailto:).
# NEXT_PUBLIC_BETA=1
# NEXT_PUBLIC_BETA_FEEDBACK_URL="https://github.com/org/repo/issues/new?template=beta.md"

# MatchProp Web — Producción
# Copiar a .env.local y completar. Next.js usa .env.local en build/runtime.

# URL de la API (para rewrites /api/*)
API_SERVER_URL="https://api.tu-dominio.com"
NEXT_PUBLIC_API_URL="https://api.tu-dominio.com"

# Branding
NEXT_PUBLIC_PRODUCT_NAME="MatchProp"
NEXT_PUBLIC_BUILD_ID="prod"
